{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=iko.db"
  },
  "App": {
    "ApiBaseUrl": "http://127.0.0.1:5000",
    "WebBaseUrl": "http://localhost:4200"
  },
  "Jwt": {
    "Key": "dev-only-insecure-jwt-key-change-me-in-production",
    "Issuer": "iko",
    "Audience": "iko-web",
    "ExpiresInDays": 7
  }
}
